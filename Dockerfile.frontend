# Dockerfile for Streamlit Dashboard
FROM python:3.11-slim

WORKDIR /app

# Install dependencies
RUN pip install --no-cache-dir \
    streamlit==1.31.0 \
    requests==2.31.0 \
    plotly==5.18.0

# Copy frontend code
COPY frontend/ ./frontend/

# Expose Streamlit port
EXPOSE 8501

# Run Streamlit
CMD ["streamlit", "run", "frontend/ops_dashboard.py", "--server.port=8501", "--server.address=0.0.0.0"]

